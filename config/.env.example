# Optional overrides for r1-stock-bridge.
# Copy this file to config/.env and fill in your own values.
# Do not commit config/.env to a public repository.

R1LAB_OPENAI_PROVIDER=
R1LAB_OPENAI_BASE_URL=
R1LAB_OPENAI_API_KEY=
R1LAB_OPENAI_MODEL=
R1LAB_WIRE_API=responses
R1LAB_PREFER_SSE=true
R1LAB_OPENAI_TIMEOUT_SECONDS=20
R1LAB_ERROR_FALLBACK_TEXT=我现在暂时无法回答，请稍后再试。
R1LAB_HA_ENABLED=false
R1LAB_HA_BASE_URL=http://127.0.0.1:8123
R1LAB_HA_ACCESS_TOKEN=
R1LAB_HA_REFRESH_TOKEN=
R1LAB_HA_CLIENT_ID=
R1LAB_HA_TIMEOUT_SECONDS=8
R1LAB_HA_CACHE_SECONDS=15
R1LAB_HOST=0.0.0.0
R1LAB_PORT=18888
R1LAB_PORTS=80,18888
# Only needed for ADB helper scripts.
R1LAB_R1_IP=
R1LAB_ADB_BIN=/tmp/platform-tools/adb
R1LAB_R1_REMOTE_HOST=39.105.252.245
R1LAB_R1_REMOTE_PORT=80
R1LAB_R1_REMOTE_HOST_HEADER=127.0.0.1:18888
R1LAB_TTS_MAX_CHARS=72
R1LAB_STREAM_WAIT_SECONDS=4.0
R1LAB_STREAM_IDLE_SECONDS=0.6
R1LAB_MUSIC_ENABLED=false
R1LAB_MUSIC_ENDPOINT=http://127.0.0.1:3900
R1LAB_MUSIC_TIMEOUT_SECONDS=8
R1LAB_MUSIC_MAX_RESULTS=5
R1LAB_MUSIC_LEVEL=exhigh
R1LAB_MUSIC_PUBLIC_BASE_URL=http://asrv3.hivoice.cn
R1LAB_MUSIC_CACHE_SECONDS=1800
R1LAB_MUSIC_COOKIE_FILE=/opt/r1-stock-bridge/data/music_cookie.txt
